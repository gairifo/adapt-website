# Copy to .env for local `vercel dev` testing. In production, set these as
# Vercel project environment variables instead — never commit real values.

# XScience CRM (Adapt's own instance, crm.adapt-systems.com) — same API
# used by agent-loops/target-scanner and agent-loops/linkedin-enrichment.
CRM_BASE_URL=https://crm.adapt-systems.com
CRM_API_KEY=

# Transactional email notification for new leads (default: Resend)
EMAIL_API_KEY=
LEAD_NOTIFICATION_FROM=leads@adapt-systems.com
LEAD_NOTIFICATION_TO=hello@adapt-systems.com
